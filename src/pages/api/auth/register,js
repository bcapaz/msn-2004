import prisma from '../../../lib/prisma';

export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).end();
  
  const { delegacao, password, avatarUrl } = req.body;

  try {
    const newUser = await prisma.user.create({
      data: {
        username: delegacao,
        display_name: delegacao,
        email: `${delegacao.toLowerCase().replace(/\s/g, '')}@modelo.com`,
        password: password,
        avatar_url: avatarUrl || '/images/avatar-blue.png'
      }
    });
    res.status(200).json(newUser);
  } catch (error) {
    res.status(400).json({ message: 'Nome de delegação já existe.' });
  }
}
